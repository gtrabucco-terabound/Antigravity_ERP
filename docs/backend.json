{
  "entities": {
    "Tenant": {
      "title": "Tenant",
      "description": "Representa una organización o cliente independiente en la plataforma multi-inquilino.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Nombre de la empresa o tenante."
        },
        "country": {
          "type": "string",
          "description": "País de operación principal."
        },
        "status": {
          "type": "string",
          "enum": ["active", "suspended"],
          "description": "Estado actual del tenante."
        },
        "planId": {
          "type": "string",
          "description": "ID del plan de suscripción asociado."
        },
        "activeModules": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Lista de IDs de módulos activados para este tenante."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Fecha de creación del registro."
        }
      },
      "required": ["name", "country", "status", "planId"]
    },
    "Module": {
      "title": "Module",
      "description": "Representa un módulo o micro-frontend disponible en la plataforma.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "remoteUrl": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["active", "inactive"]
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["name", "version", "remoteUrl", "status"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/_gl_tenants/{tenantId}": {
      "schema": "Tenant",
      "description": "Colección global de tenantes registrados en la plataforma."
    },
    "/_gl_modules/{moduleId}": {
      "schema": "Module",
      "description": "Catálogo global de módulos registrados."
    }
  }
}