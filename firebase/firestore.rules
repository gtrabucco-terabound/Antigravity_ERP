rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // BACKEN Global governance collections
    match /_gl_{collection}/{document=**} {
      // Access ONLY to platform administrators
      allow read, write: if request.auth != null && 
                          request.auth.token.role == "PlatformAdmin";
    }

    // Default deny for all other paths to ensure tenant isolation at the rules level
    match /{document=**} {
      allow read, write: if false;
    }
  }
}