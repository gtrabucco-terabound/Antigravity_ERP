rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Reglas globales para la gestión de tenantes y gobernanza
    match /_gl_tenants/{tenantId} {
      allow read, write: if true;
    }

    match /_gl_modules/{moduleId} {
      allow read, write: if true;
    }

    // Regla por defecto para el resto de la base de datos
    match /{document=**} {
      allow read, write: if request.time < timestamp.date(2026, 4, 17);
    }
  }
}